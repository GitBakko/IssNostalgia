theme_override_colors/font_outline_color = Color(0, 0, 0, 0.85)
theme_override_constants/outline_size = 4
theme_override_font_sizes/font_size = 16
text = "IssNostalgia — Physics Sandbox  (Sprint 02)
SPACE   vertical          (15 m/s, light spin)
H       horizontal +X     (20 m/s, topspin)
1       Tiro a giro       → mouse  (25 m/s @15°, sidespin 8, topspin 2)
2       Foglia morta      → mouse  (22 m/s @20°, backspin 6, sidespin 3)
3       Rasoterra forte   → mouse  (30 m/s @1°,  topspin 4)
4       Knuckleball       → mouse  (28 m/s @10°, ~zero spin)
5       Rasoterra medio   → mouse  (15 m/s @3°,  topspin 4)
6       Rasoterra debole  → mouse  (10 m/s @1°,  topspin 4)
LMB     lob to clicked ground point
RMB drag  orbit camera (yaw/pitch)
wheel   zoom in / out
R       reset to spawn (ground)
W       toggle dry / wet surface (global)
        + roll through the blue patch (wet zone)
F5      toggle slow-motion (0.25x)
F1      debug UI panel (sliders, presets, force readout)
G       3D force gizmo
        viola=gravity  rosso=drag  verde=magnus
        giallo=knuckle  blu=grass  bianco=net (sum)
P       toggle replay (pause/resume from cursor)
. / ,   replay step +1 / -1 physics tick
ESC     quit"

