# Godot 4 — official template
.godot/
.import/
export.cfg
export_presets.cfg
*.translation
# Note: keep `*.import` sidecar files committed alongside their source assets.
# Godot best practice — they record reproducible import settings.

# Godot .NET / Mono
.mono/
data_*/
mono_crash.*.json

# .NET / C#
bin/
# Keep the imgui-godot GDExtension binaries — they ARE the addon runtime,
# not C# build output, and Godot needs them at editor + export time.
!addons/imgui-godot/bin/
!addons/imgui-godot/bin/**
# But IGNORE the `~`-prefixed hot-reload copies Godot creates next to
# each GDExtension binary on Windows — they're per-run temporaries that
# get re-generated on every editor launch and can lock under AV / locks.
addons/imgui-godot/bin/~*
addons/imgui-godot/bin/**/~*
obj/
*.user
*.suo
*.csproj.user
*.sln.docstates
project.lock.json
*.pidb
*.svd
*.userprefs

# Visual Studio / Rider / VSCode
.vs/
.vscode/
.idea/

# OS
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store
*~

# Build artifacts
*.apk
*.aab
*.ipa
*.app
android/build/
build/
dist/
*.dmg
*.zip
*.tar.gz

# Logs / temp
*.log
tests/last_run.log

# Local screenshots (validation artifacts, not source)
t*_screenshot.png
t*_screenshot.png.import
t_*.png
t_*.png.import
screenshots/

# Stray ephemera that PowerShell redirections can leave behind
1e-*
target
void
Color
Vector*
PackedVector*
this
This
BOUNCE_*
ROLLING_*

# Backups (runtime-generated, not source)
resources/backups/*.tres
!resources/backups/.gdkeep

# Local env / secrets
.env
.env.local
*.secret

# Claude Code / Ruflo tooling (per-user, not project source)
.claude/
.claude-flow/
.planning/
.code-review-graph/
.swarm/
ruvector.db
ruvector.db-journal
